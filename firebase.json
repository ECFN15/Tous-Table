{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "dist",
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.git",
      "**/.github",
      "**/.gitignore",
      "**/.env*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/index.html",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/atelier",
        "destination": "/a-propos",
        "type": 301
      },
      {
        "source": "/meubles-anciens/",
        "destination": "/meubles-anciens",
        "type": 301
      },
      {
        "source": "/meubles-anciens/buffets/",
        "destination": "/meubles-anciens/buffets",
        "type": 301
      },
      {
        "source": "/meubles-anciens/tables-de-ferme/",
        "destination": "/meubles-anciens/tables-de-ferme",
        "type": 301
      },
      {
        "source": "/meubles-anciens/armoires/",
        "destination": "/meubles-anciens/armoires",
        "type": 301
      },
      {
        "source": "/meubles-anciens/commodes-chevets/",
        "destination": "/meubles-anciens/commodes-chevets",
        "type": 301
      },
      {
        "source": "/meubles-anciens/chaises-bancs/",
        "destination": "/meubles-anciens/chaises-bancs",
        "type": 301
      },
      {
        "source": "/meubles-anciens/autres/",
        "destination": "/meubles-anciens/autres",
        "type": 301
      },
      {
        "source": "/planches-a-decouper-anciennes/",
        "destination": "/planches-a-decouper-anciennes",
        "type": 301
      },
      {
        "source": "/comptoir/",
        "destination": "/comptoir",
        "type": 301
      },
      {
        "source": "/a-propos/",
        "destination": "/a-propos",
        "type": 301
      },
      {
        "source": "/livraison-meubles-anciens-france/",
        "destination": "/livraison-meubles-anciens-france",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/sitemap.xml",
        "function": "sitemap"
      },
      {
        "source": "/produit/**",
        "function": "renderPage"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://apis.google.com https://www.gstatic.com https://www.google.com https://js.stripe.com https://*.firebaseapp.com https://pagead2.googlesyndication.com https://googleads.g.doubleclick.net https://tpc.googlesyndication.com; worker-src 'self' blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob: https://*.stripe.com https://firebasestorage.googleapis.com https://storage.googleapis.com; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://*.cloudfunctions.net https://api.stripe.com https://m.stripe.network https://firebasestorage.googleapis.com https://ip-api.com https://*.firebaseapp.com https://api-adresse.data.gouv.fr https://pagead2.googlesyndication.com https://googleads.g.doubleclick.net; frame-src 'self' https://accounts.google.com https://js.stripe.com https://www.google.com https://www.youtube.com https://recaptcha.google.com https://hooks.stripe.com https://*.firebaseapp.com https://pagead2.googlesyndication.com https://googleads.g.doubleclick.net https://tpc.googlesyndication.com;"
          }

        ]
      },
      {
        "source": "{/,/index.html,/**/*.html}",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|gif|png|webp|svg|css|js)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  }
}
