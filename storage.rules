rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      // Seul l'admin peut uploader des fichiers
      allow write: if request.auth != null && 
                   request.auth.token.email == 'matthis.fradin2@gmail.com';
    }
  }
}
