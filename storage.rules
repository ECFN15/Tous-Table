rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      // Seul l'admin peut uploader des fichiers
      allow delete: if request.auth != null && (
                   request.auth.token.email == 'matthis.fradin2@gmail.com' ||
                   request.auth.token.admin == true
      );
      
      allow create, update: if request.auth != null && (
                   request.auth.token.email == 'matthis.fradin2@gmail.com' ||
                   request.auth.token.admin == true
      ) && request.resource.size < 20 * 1024 * 1024 // Max 20MB
        && request.resource.contentType.matches('image/.*'); // Images uniquement
    }
  }
}
