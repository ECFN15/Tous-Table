rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonction Admin SÉCURISÉE - Supporte Email (Legacy) OU Custom Claim (Recommended)
    function isArtisan() {
      return request.auth != null && (
        request.auth.token.email.lower() == 'matthis.fradin2@gmail.com' ||
        request.auth.token.admin == true
      );
    }

    // Validation Helpers
    // ---------------------------------------------------------
    // Fonction de Validation des Produits (Schema Enforcement)
    function isValidProduct() {
      let data = request.resource.data;
      return 
        // 1. Informations Textuelles
        data.name is string && data.name.size() > 0 && data.name.size() < 140 &&
        data.description is string && data.description.size() < 10000 &&
        
        // 2. Données Financières (Nombres obligatoires)
        (data.currentPrice is number || data.currentPrice is float) &&
        (data.startingPrice is number || data.startingPrice is float) &&
        
        // 3. Structure d'Images
        (data.images is list) &&
        (!("thumbnails" in data) || data.thumbnails is list) && // Optionnel pour rétrocompatibilité
        
        // 4. Logique Enchère
        (data.auctionActive is bool);
    }

    // Collections produits (furniture, cutting_boards, etc.)
    match /artifacts/tat-made-in-normandie/public/data/{collectionName}/{itemId} {
      allow read: if true;
      
      // ADMIN : Création et Modification avec VALIDATION STRICTE
      allow create, update: if isArtisan() && isValidProduct();
      
      // ADMIN : Suppression sans validation de payload
      allow delete: if isArtisan();
        
      match /bids/{bidId} {
        allow read: if true;
        allow create: if false; // Via Cloud Function uniquement
      }

      // Commentaires - Utilisateurs authentifiés peuvent créer/lire/supprimer LEURS commentaires
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isArtisan());
      }

      // Likes - Utilisateurs authentifiés peuvent créer/lire/supprimer LEUR like
      // L'ID du document DOIT être l'UID de l'utilisateur pour garantir l'unicité (1 like par user)
      match /likes/{userId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Shares
      match /shares/{userId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == userId;
      }

      // Logs
      match /logs/{logId} {
        allow create: if request.auth != null;
        allow read, delete: if isArtisan();
      }
    }

    // Panier utilisateur - Isolation par userId
    match /users/{userId}/cart/{cartItem} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Commandes - Accès Admin Total
    match /orders/{orderId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'matthis.fradin2@gmail.com';
      // Pour les clients
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId);
      allow create: if false; // Toujours via Cloud Function uniquement
    }

    // System Metadata
    match /sys_metadata/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'matthis.fradin2@gmail.com';
    }
  }
}
