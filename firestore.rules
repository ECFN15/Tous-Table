rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonction Admin SÉCURISÉE - Supporte Email (Legacy) OU Custom Claim (Recommended)
    function isArtisan() {
      return request.auth != null && (
        request.auth.token.email.lower() == 'matthis.fradin2@gmail.com' ||
        request.auth.token.admin == true
      );
    }

    // Collections produits (furniture, cutting_boards, etc.)
    match /artifacts/tat-made-in-normandie/public/data/{collectionName}/{itemId} {
      allow read: if true;
      // SEUL L'ADMIN PEUT CRÉER/SUPPRIMER des produits
      allow create, delete: if isArtisan();
      // Mise à jour: SEUL L'ADMIN. Les likes/shares passent par Cloud Functions maintenant.
      allow update: if isArtisan();
        
      match /bids/{bidId} {
        allow read: if true;
        // Création uniquement via Cloud Function (Admin SDK)
        allow create: if false;
      }

      // Commentaires - Utilisateurs authentifiés peuvent créer/lire
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        // Suppression: propriétaire du commentaire ou admin
        allow delete: if request.auth != null && 
          (resource.data.userId == request.auth.uid || isArtisan());
      }

      // Logs - Authentification requise (anti-spam)
      match /logs/{logId} {
        allow create: if request.auth != null;
        allow read, delete: if isArtisan();
      }
    }

    // Panier utilisateur - Isolation par userId
    match /users/{userId}/cart/{cartItem} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Commandes - Accès Admin Total
    match /orders/{orderId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'matthis.fradin2@gmail.com';
      // Pour les clients
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId);
      allow create: if false; // Toujours via Cloud Function uniquement
    }

    // System Metadata
    match /sys_metadata/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'matthis.fradin2@gmail.com';
    }
  }
}
