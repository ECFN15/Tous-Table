rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonction Admin SÉCURISÉE - Un seul email autorisé
    function isArtisan() {
      return request.auth != null && 
             request.auth.token.email == 'matthis.fradin2@gmail.com';
    }

    // Collections produits (furniture, cutting_boards, etc.)
    match /artifacts/tat-made-in-normandie/public/data/{collectionName}/{itemId} {
      allow read: if true;
      // SEUL L'ADMIN PEUT CRÉER/SUPPRIMER des produits
      allow create, delete: if isArtisan();
      // Mise à jour: Admin OU utilisateurs auth (pour likeCount, shareCount, commentCount)
      allow update: if isArtisan() || request.auth != null;
        
      match /bids/{bidId} {
        allow read: if true;
        // Création uniquement via Cloud Function (Admin SDK)
        allow create: if false;
      }

      // Commentaires - Utilisateurs authentifiés peuvent créer/lire
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        // Suppression: propriétaire du commentaire ou admin
        allow delete: if request.auth != null && 
          (resource.data.userId == request.auth.uid || isArtisan());
      }

      // Logs - Authentification requise (anti-spam)
      match /logs/{logId} {
        allow create: if request.auth != null;
        allow read, delete: if isArtisan();
      }
    }

    // Panier utilisateur - Isolation par userId
    match /users/{userId}/cart/{cartItem} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Commandes - Lecture/écriture restreinte
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && 
        (request.auth.uid == resource.data.userId || isArtisan());
    }
  }
}
