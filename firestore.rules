rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonction Admin SÉCURISÉE - Supporte Email (Legacy) OU Custom Claim (Recommended)
    function isArtisan() {
      return request.auth != null && (
        request.auth.token.email.lower() == 'matthis.fradin2@gmail.com' ||
        request.auth.token.admin == true
      );
    }

    // Fonction Validation User (Basic)
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isArtisan();
      allow create: if isOwner(userId); // Permet la création automatique à la première connexion
      allow update: if isOwner(userId) || isArtisan();
    }

    // Validation Helpers
    // ---------------------------------------------------------
    // Fonction de Validation des Produits Affiliés
    function isValidAffiliateProduct() {
      let data = request.resource.data;
      return
        data.name is string && data.name.size() > 0 && data.name.size() < 255 &&
        data.brand is string && data.brand.size() > 0 &&
        data.category is string && data.category.size() > 0 &&
        data.tier is string && data.tier in ['essentiel', 'premium', 'expert'] &&
        (data.price == null || (data.price is number && data.price >= 0)) &&
        data.affiliateUrl is string && data.affiliateUrl.size() > 5 &&
        data.affiliateProgram is string && data.affiliateProgram.size() > 0 &&
        data.status is string && data.status in ['published', 'draft'];
    }

    // Fonction de Validation des Produits (Schema Enforcement)
    function isValidProduct() {
      let data = request.resource.data;
      return 
        // 1. Informations Textuelles
        data.name is string && data.name.size() > 0 && data.name.size() < 140 &&
        data.description is string && data.description.size() < 10000 &&
        
        // 2. Données Financières (Nombres obligatoires et positifs)
        (!("currentPrice" in data) || (data.currentPrice is number && data.currentPrice >= 0)) &&
        (!("startingPrice" in data) || (data.startingPrice is number && data.startingPrice >= 0)) &&
        
        // 3. Structure d'Images
        (data.images is list) &&
        (!("thumbnails" in data) || data.thumbnails is list) && 
        
        // 4. Logique Enchère
        (!("auctionActive" in data) || data.auctionActive is bool);
    }

    // Produits affiliés — validation schema spécifique (écrase la validation générique)
    match /artifacts/{appId}/public/data/affiliate_products/{productId} {
      allow read: if true;
      allow create, update: if isArtisan() && isValidAffiliateProduct();
      allow delete: if isArtisan();
    }

    // Tracking clics affiliation — création par utilisateurs auth, lecture admin
    match /affiliate_clicks/{clickId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['productId', 'productName', 'affiliateProgram', 'category', 'tier', 'timestamp', 'sessionId', 'referrer'])
        && request.resource.data.productId is string
        && request.resource.data.productId.size() > 0;
      allow read: if isArtisan();
    }

    // Collections produits (furniture, cutting_boards, etc.)
    match /artifacts/{appId}/public/data/{collectionName}/{itemId} {
      allow read: if true;
      
      // ADMIN : Création et Modification avec VALIDATION STRICTE
      allow create, update: if isArtisan() && isValidProduct();
      
      // ADMIN : Suppression sans validation de payload
      allow delete: if isArtisan();
        
      match /bids/{bidId} {
        allow read: if true;
        allow create: if false; // Via Cloud Function uniquement
      }


    }

    // Newsletter Subscribers - Authenticated users can subscribe, Admin can read/manage
    match /newsletter_subscribers/{docId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['contactInfo', 'firstName', 'lastName', 'createdAt', 'source'])
        && request.resource.data.firstName is string
        && request.resource.data.firstName.size() > 0
        && request.resource.data.firstName.size() < 100
        && request.resource.data.lastName is string
        && request.resource.data.lastName.size() > 0
        && request.resource.data.lastName.size() < 100
        && request.resource.data.source is string;
      allow read, update, delete: if isArtisan();
    }

    // Fonction Validation Cart
    function isValidCartItem() {
      let data = request.resource.data;
      return 
        data.keys().size() < 10 &&
        (data.quantity is number && data.quantity > 0) &&
        (data.price is number && data.price >= 0);
    }

    // Panier utilisateur - Isolation + Validation Anti-Flood
    match /users/{userId}/cart/{cartItem} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId && (isValidCartItem() || request.method == 'delete');
    }

    // Commandes - Accès Admin Total + Client (Lecture seule sur siennes)
    match /orders/{orderId} {
      allow read, write: if isArtisan(); // Utilisation du helper unifié
      allow read: if request.auth != null && request.auth.token.email_verified == true && (
        request.auth.uid == resource.data.userId || 
        request.auth.token.email == resource.data.userEmail
      );
      allow create: if false; // Toujours via Cloud Function uniquement
    }

    // System Metadata - PROTECTION CRITIQUE ADMIN
    // System Metadata - PROTECTION CRITIQUE ADMIN
    match /sys_metadata/{docId} {
      // Toutes les métadonnées système (Thème, Images, Contact) sont publiques !
      allow read: if true;
      allow write: if isArtisan();
    }

    // ============================================================
    // SÉCURITÉ: Collections système (Backend-Only via Admin SDK)
    // ============================================================
    // Ces collections sont gérées EXCLUSIVEMENT par les Cloud Functions
    // Aucun client ne peut y accéder directement

    // Rate Limiting pour les enchères
    match /sys_ratelimit/{docId} {
      allow read, write: if false; // Backend Admin SDK uniquement
    }

    // Clés d'idempotence (anti-doublon enchères)
    match /sys_idempotency/{docId} {
      allow read, write: if false; // Backend Admin SDK uniquement
    }

    // Analytics Dashboard (Sessions)
    match /analytics_sessions/{docId} {
      allow read: if isArtisan(); // Admins only
      allow write: if false; // Managed by Cloud Functions
    }
  }
}
