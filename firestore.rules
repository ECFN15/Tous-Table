rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonction Admin SÉCURISÉE - Supporte Email (Legacy) OU Custom Claim (Recommended)
    function isArtisan() {
      return request.auth != null && (
        request.auth.token.email.lower() == 'matthis.fradin2@gmail.com' ||
        request.auth.token.admin == true
      );
    }

    // Collections produits (furniture, cutting_boards, etc.)
    match /artifacts/tat-made-in-normandie/public/data/{collectionName}/{itemId} {
      allow read: if true;
      // SEUL L'ADMIN PEUT CRÉER/SUPPRIMER/MODIFIER des produits
      allow write: if isArtisan();
        
      match /bids/{bidId} {
        allow read: if true;
        allow create: if false; // Via Cloud Function uniquement
      }

      // Commentaires - Utilisateurs authentifiés peuvent créer/lire/supprimer LEURS commentaires
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isArtisan());
      }

      // Likes - Utilisateurs authentifiés peuvent créer/lire/supprimer LEUR like
      // L'ID du document DOIT être l'UID de l'utilisateur pour garantir l'unicité (1 like par user)
      match /likes/{userId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Shares
      match /shares/{userId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == userId;
      }

      // Logs
      match /logs/{logId} {
        allow create: if request.auth != null;
        allow read, delete: if isArtisan();
      }
    }

    // Panier utilisateur - Isolation par userId
    match /users/{userId}/cart/{cartItem} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Commandes - Accès Admin Total
    match /orders/{orderId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'matthis.fradin2@gmail.com';
      // Pour les clients
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId);
      allow create: if false; // Toujours via Cloud Function uniquement
    }

    // System Metadata
    match /sys_metadata/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'matthis.fradin2@gmail.com';
    }
  }
}
